{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Transcription Sidecar Schema",
  "description": "Metadata sidecar for transcribed person clips (output of transcribe_video_clips.py or transcribe_audio_files.py)",
  "type": "object",
  "required": [
    "uuid",
    "schema_version",
    "transcriber",
    "transcribed_at",
    "transcription"
  ],
  "oneOf": [
    {
      "required": ["parent_clip"],
      "description": "Video-clip transcription (transcribe_video_clips.py)"
    },
    {
      "required": ["parent_audio"],
      "description": "Standalone audio-file transcription (transcribe_audio_files.py)"
    }
  ],
  "properties": {
    "uuid": {
      "type": "string",
      "description": "Unique identifier (UUID v4) for this transcription",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "schema_version": {
      "type": "string",
      "description": "Version of this schema (e.g., '1.0')",
      "enum": ["1.0"]
    },
    "parent_clip": {
      "type": "object",
      "description": "Reference to the parent person clip this transcribes (video pipeline)",
      "required": ["uuid", "file"],
      "properties": {
        "uuid": {
          "type": "string",
          "description": "UUID of the parent person clip",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "file": {
          "type": "string",
          "description": "Filename of the parent person clip video"
        }
      }
    },
    "parent_audio": {
      "type": "object",
      "description": "Reference to the parent audio file this transcribes (audio pipeline)",
      "required": ["filename"],
      "properties": {
        "filename": {
          "type": "string",
          "description": "Filename of the parent audio file"
        }
      }
    },
    "transcriber": {
      "type": "object",
      "description": "Transcription model and method information",
      "properties": {
        "method": {
          "type": "string",
          "description": "Transcription method used",
          "enum": ["openai_whisper"]
        },
        "model_size": {
          "type": "string",
          "description": "Whisper model size used",
          "enum": ["tiny", "base", "small", "medium", "large", "large-v3"]
        }
      }
    },
    "transcribed_at": {
      "type": "string",
      "description": "ISO 8601 timestamp when transcription was created",
      "format": "date-time"
    },
    "transcription": {
      "type": "string",
      "description": "The transcribed text from the audio track"
    },
    "language": {
      "type": "string",
      "description": "Detected language (ISO 639-1 code, e.g., 'en', 'fr')"
    },
    "duration_seconds": {
      "type": "number",
      "description": "Duration of the audio transcribed (seconds)",
      "minimum": 0
    },
    "processing_info": {
      "type": "object",
      "description": "Additional processing metadata",
      "properties": {
        "audio_format": {
          "type": "string",
          "description": "Audio format extracted from video"
        },
        "audio_sample_rate": {
          "type": "integer",
          "description": "Sample rate of audio (Hz)"
        }
      }
    },
    "segments": {
      "type": "array",
      "description": "Segment-level transcription data from Whisper with timestamps",
      "items": {
        "type": "object",
        "properties": {
          "start": {
            "type": "number",
            "description": "Start time of segment in seconds"
          },
          "end": {
            "type": "number",
            "description": "End time of segment in seconds"
          },
          "text": {
            "type": "string",
            "description": "Transcribed text for this segment"
          }
        },
        "required": ["start", "end", "text"]
      }
    }
  }
}
