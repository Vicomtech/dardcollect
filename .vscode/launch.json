    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "[1] Download media from archive.org",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/download_media_from_archive.py",
            "console": "integratedTerminal"
        },
        {
            "name": "[2A] Extract person clips from videos",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/extract_person_clips_from_videos.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[2B] Extract persons from images",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/extract_persons_from_images.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[3] Extract face crops from videos",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/extract_face_crops_from_videos.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[3B] Extract face crops from images",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/extract_face_crops_from_images.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[4] Filter face crops by quality (convergent)",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/filter_face_crops_by_quality.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[5] Annotate face quality",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/annotate_face_quality.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[6] Extract frames from videos",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/extract_frames_from_videos.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[7A] Transcribe video clips",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/transcribe_video_clips.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[7B] Transcribe audio files",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/transcribe_audio_files.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "[7C] Extract text from documents",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/extract_text_from_doc.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
            "name": "Index data for viewer",
            "type": "debugpy",
            "request": "launch",
            "program": "viewer/index_data.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Start web server",
            "type": "debugpy",
            "request": "launch",
            "module": "http.server",
            "args": ["8080"],
            "cwd": "${workspaceFolder}/viewer",
            "console": "integratedTerminal"
        }
    ],
    "inputs": []
}