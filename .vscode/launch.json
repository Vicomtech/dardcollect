            "subProcess": false
        },
        {
            "name": "[2B] Extract persons from images",
            "type": "debugpy",
            "request": "launch",
            "program": "pipeline/extract_persons_from_images.py",
            "console": "integratedTerminal",
            "subProcess": false
        },
        {
