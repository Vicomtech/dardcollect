__pycache__/
*.pyc
.venv/
venv/
env/
.env
.DS_Store
*.egg-info/
dist/
build/
.idea/
*.engine
*.profile
# onnxsim / ONNX Runtime simplified-model caches — regenerated locally by
# dardcollect/onnx_utils.ensure_simplified_onnx. The original .onnx models are
# bundled (committed); a couple of .simplified.onnx are committed historically,
# these ignore new locally-generated copies so ~hundreds of MB don't enter git.
*.simplified.onnx
# Whisper download cache (the bundled model is dardcollect/models/openai_whisper_small.pt).
dardcollect/models/small.pt
viewer/data_link
viewer/data_index.json
DARD/
# .claude/ — project skills + settings.json are committed (portable, shared with
# collaborators, same convention as the sibling Motion_Tracking_Backend_update
# repo). Only local/personal artifacts under .claude/ stay ignored.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
# .github/ is committed — copilot-instructions.md + instructions/*.instructions.md
# are the Copilot equivalent of .claude/skills/ and travel with the repo.
.qdrant-initialized
storage/
# snapshots/ holds local golden baselines (normalized SHA-256 manifests of the
# gitignored DARD/ outputs). They are machine/dataset-specific — each machine
# captures its own via scripts/golden_snapshot.py and the user ratifies it.
# The harness itself (scripts/golden_snapshot.py) is committed.
snapshots/
DARD_test/
# Fast-fixture gate (scripts/run_pipeline.py --config config.test.yaml): the
# media, the generated test config, and the fixture baseline are all local/
# per-machine (derived from the gitignored DARD/ dataset). The committed
# artifacts are the GENERATORS + harness: scripts/make_fixture_media.py,
# scripts/make_test_config.py, scripts/run_pipeline.py, scripts/golden_snapshot.py.
tests/fixtures/media/
tests/fixtures/golden_manifest.json
config.test.yaml
# Local per-machine dataset configs (custom non-Archive.org datasets with
# machine-specific input/output paths). config.yaml stays committed as the
# portable template. Add config.<dataset>.yaml here when it carries absolute
# or UNC paths that would not resolve on other machines.
config.prolific.yaml

# Pipeline run logs (created by scripts/run_pipeline.py via `tee`) and
# moviepy/temp_audio temp files. These are local-only by-products of
# debugging or testing — never commit them.
*.log
temp-audio-*.m4a
